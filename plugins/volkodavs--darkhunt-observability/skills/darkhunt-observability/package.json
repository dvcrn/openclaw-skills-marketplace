{
  "name": "@openclaw/tracehub-telemetry",
  "version": "0.1.0",
  "description": "OpenClaw Trace Hub telemetry plugin — emits OTel trace spans to Trace Hub",
  "type": "module",
  "main": "dist/index.js",
